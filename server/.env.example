# === gallery-ai-proxy — konfiguracja (SKOPIUJ do server/.env i uzupełnij) ===
# server/.env jest gitignored — realny klucz deAPI NIGDY nie trafia do repo.

# Klucz deAPI — format `<id>|<token>` (np. 13660|xxxxxxxx…), WKLEJ DOKŁADNIE jak w panelu deAPI.
# UWAGA: NIE dodawaj żadnego prefiksu (np. dpn-sk-) — proxy wysyła wartość 1:1 jako klucz API.
# Trzymany TYLKO tutaj / w zmiennych Railway. Nigdy w repo ani w apce.
DEAPI_API_KEY=00000|xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Endpoint OpenAI-compatible deAPI (raczej nie zmieniać)
DEAPI_BASE_URL=https://oai.deapi.ai/v1

# Model + kroki edycji (Flux.2 Klein 4B = distilled, 4 kroki wystarczą). Zmiana tutaj = zmiana bez przebudowy APK.
DEAPI_MODEL=Flux_2_Klein_4B_BF16
DEAPI_STEPS=4
# Opcjonalnie osobny model/kroki do generative-fill (domyślnie = powyższe):
# DEAPI_FILL_MODEL=QwenImageEdit_Plus_NF4
# DEAPI_FILL_STEPS=4

# Współdzielony sekret apka↔proxy (apka wysyła go w nagłówku X-App-Key). Chroni kredyty, gdyby URL wyciekł.
APP_KEY=change-me-to-a-long-random-string

# CORS — originy dopuszczone w przeglądarce (po przecinku). Domyślnie porty Expo web (dev).
# Natywne żądania z telefonu nie wysyłają Origin, więc działają zawsze niezależnie od tej listy.
# ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006

# Port lokalny (Railway sam wstrzykuje PORT — nie ustawiaj go tam)
PORT=8787
