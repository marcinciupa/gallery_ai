# === gallery-ai-proxy — konfiguracja (SKOPIUJ do server/.env i uzupełnij) ===
# server/.env jest gitignored — realne sekrety NIGDY nie trafiają do repo.

# Klucz deAPI. Format panelu: `<id>|<token>` (np. 13660|xxxx…). Proxy używa natywnego REST v2 (api.deapi.ai),
# który NIE przyjmuje prefiksu `dpn-sk-` — serwer i tak go odcina, więc możesz trzymać klucz z prefiksem
# lub bez (kompatybilnie z poprzednią konfiguracją OpenAI-compat). Trzymany TYLKO tutaj / w zmiennych Railway.
DEAPI_API_KEY=dpn-sk-00000|xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model + kroki edycji img2img (Flux.2 Klein 4B = distilled, 4 kroki wystarczą). Alternatywa: QwenImageEdit_Plus_NF4.
DEAPI_MODEL=Flux_2_Klein_4B_BF16
DEAPI_STEPS=4

# Dedykowany model usuwania tła (deAPI v2). Alternatywa: RMBG-1.4
DEAPI_BG_MODEL=Ben2

# Dedykowany model upscalu (deAPI v2, x4)
DEAPI_UPSCALE_MODEL=RealESRGAN_x4

# WEBHOOKI (opcjonalne, ale zalecane w produkcji): sekret HMAC do weryfikacji callbacków deAPI (min. 32 znaki).
# Bez tego (lub bez publicznego URL) proxy działa na pollingu. Na Railway ustaw w Variables.
# DEAPI_WEBHOOK_SECRET=twoj-64-znakowy-sekret

# Publiczny URL proxy (do webhook_url). Na Railway wykrywany automatycznie z RAILWAY_PUBLIC_DOMAIN — nie ustawiaj.
# Lokalnie webhooki wymagają tunelu (np. ngrok) i ustawienia PUBLIC_URL; bez tego = polling.
# PUBLIC_URL=https://twoje-proxy.up.railway.app

# Współdzielony sekret apka↔proxy (apka wysyła go w nagłówku X-App-Key). Chroni kredyty, gdyby URL wyciekł.
APP_KEY=change-me-to-a-long-random-string

# CORS — originy dopuszczone w przeglądarce (po przecinku). Domyślnie porty Expo web (dev).
# Natywne żądania z telefonu nie wysyłają Origin, więc działają zawsze niezależnie od tej listy.
# ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006

# Port lokalny (Railway sam wstrzykuje PORT — nie ustawiaj go tam)
PORT=8787
